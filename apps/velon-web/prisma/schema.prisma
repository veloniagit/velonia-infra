generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["catalogo", "comercial", "crm", "dashboard", "financeiro", "public"]
}

model atividades {
  id              BigInt                   @id @default(autoincrement())
  lead_id         BigInt?
  oportunidade_id BigInt?
  vendedor_id     BigInt?
  tipo            String                   @db.VarChar(50)
  titulo          String                   @db.VarChar(255)
  descricao       String?
  agendado_para   DateTime?                @db.Timestamptz(6)
  concluido_em    DateTime?                @db.Timestamptz(6)
  status          String                   @default("pendente") @db.VarChar(30)
  criado_em       DateTime                 @default(now()) @db.Timestamptz(6)
  leads           comercial_leads?         @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  oportunidades   comercial_oportunidades? @relation(fields: [oportunidade_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendedores      comercial_vendedores?    @relation(fields: [vendedor_id], references: [id], onUpdate: NoAction)

  @@index([status], map: "idx_atividades_status")
  @@index([vendedor_id], map: "idx_atividades_vendedor")
  @@schema("comercial")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contratos {
  id                  BigInt                 @id @default(autoincrement())
  cliente_id          BigInt?
  proposta_id         BigInt?
  vendedor_id         BigInt?
  numero              String?                @unique @db.VarChar(50)
  plano               String?                @db.VarChar(100)
  valor_implantacao   Decimal                @default(0) @db.Decimal(14, 2)
  mensalidade         Decimal                @default(0) @db.Decimal(14, 2)
  data_inicio         DateTime               @db.Date
  data_fim            DateTime?              @db.Date
  dia_vencimento      Int?
  status              String                 @default("ativo") @db.VarChar(30)
  link_documento      String?
  assinado_em         DateTime?              @db.Timestamptz(6)
  cancelado_em        DateTime?              @db.Timestamptz(6)
  motivo_cancelamento String?
  criado_em           DateTime               @default(now()) @db.Timestamptz(6)
  atualizado_em       DateTime               @default(now()) @db.Timestamptz(6)
  clientes            crm_clientes?          @relation(fields: [cliente_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  propostas           comercial_propostas?   @relation(fields: [proposta_id], references: [id], onUpdate: NoAction)
  vendedores          comercial_vendedores?  @relation(fields: [vendedor_id], references: [id], onUpdate: NoAction)
  comissoes           financeiro_comissoes[]

  @@index([cliente_id], map: "idx_contratos_cliente")
  @@index([status], map: "idx_contratos_status")
  @@schema("comercial")
}

model comercial_leads {
  id              BigInt                    @id @default(autoincrement())
  empresa         String?                   @db.VarChar(255)
  responsavel     String?                   @db.VarChar(150)
  whatsapp        String?                   @db.VarChar(30)
  email           String?                   @db.VarChar(255)
  segmento        String?                   @db.VarChar(100)
  cidade          String?                   @db.VarChar(100)
  estado          String?                   @db.VarChar(2)
  origem          String?                   @db.VarChar(100)
  temperatura     String                    @default("frio") @db.VarChar(20)
  status          String                    @default("novo") @db.VarChar(60)
  vendedor_id     BigInt?
  valor_estimado  Decimal                   @default(0) @db.Decimal(14, 2)
  ultimo_contato  DateTime?                 @db.Timestamptz(6)
  proximo_contato DateTime?                 @db.Timestamptz(6)
  observacoes     String?
  criado_em       DateTime                  @default(now()) @db.Timestamptz(6)
  atualizado_em   DateTime                  @default(now()) @db.Timestamptz(6)
  atividades      atividades[]
  vendedores      comercial_vendedores?     @relation(fields: [vendedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  oportunidades   comercial_oportunidades[]

  @@index([status], map: "idx_leads_status")
  @@index([vendedor_id], map: "idx_leads_vendedor")
  @@map("leads")
  @@schema("comercial")
}

model metas {
  id               BigInt               @id @default(autoincrement())
  vendedor_id      BigInt
  competencia      DateTime             @db.Date
  meta_implantacao Decimal              @default(0) @db.Decimal(14, 2)
  meta_mrr         Decimal              @default(0) @db.Decimal(14, 2)
  meta_clientes    Int                  @default(0)
  observacoes      String?
  criado_em        DateTime             @default(now()) @db.Timestamptz(6)
  atualizado_em    DateTime             @default(now()) @db.Timestamptz(6)
  vendedores       comercial_vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vendedor_id, competencia])
  @@index([vendedor_id], map: "idx_metas_vendedor")
  @@schema("comercial")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model comercial_oportunidades {
  id                  BigInt                @id @default(autoincrement())
  lead_id             BigInt
  vendedor_id         BigInt?
  titulo              String                @db.VarChar(255)
  etapa               String                @default("qualificacao") @db.VarChar(60)
  valor               Decimal               @default(0) @db.Decimal(14, 2)
  probabilidade       Int                   @default(0)
  previsao_fechamento DateTime?             @db.Date
  data_fechamento     DateTime?             @db.Date
  status              String                @default("aberta") @db.VarChar(30)
  motivo_perda        String?
  criado_em           DateTime              @default(now()) @db.Timestamptz(6)
  atualizado_em       DateTime              @default(now()) @db.Timestamptz(6)
  atividades          atividades[]
  leads               comercial_leads       @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendedores          comercial_vendedores? @relation(fields: [vendedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  propostas           comercial_propostas[]

  @@index([etapa], map: "idx_oportunidades_etapa")
  @@index([vendedor_id], map: "idx_oportunidades_vendedor")
  @@map("oportunidades")
  @@schema("comercial")
}

model comercial_propostas {
  id                BigInt                   @id @default(autoincrement())
  oportunidade_id   BigInt?
  vendedor_id       BigInt?
  numero            String?                  @unique @db.VarChar(50)
  titulo            String?                  @db.VarChar(255)
  plano             String?                  @db.VarChar(100)
  descricao         String?
  valor_implantacao Decimal                  @default(0) @db.Decimal(14, 2)
  mensalidade       Decimal                  @default(0) @db.Decimal(14, 2)
  desconto          Decimal                  @default(0) @db.Decimal(14, 2)
  valor_total       Decimal                  @default(0) @db.Decimal(14, 2)
  validade          DateTime?                @db.Date
  status            String                   @default("rascunho") @db.VarChar(30)
  enviada_em        DateTime?                @db.Timestamptz(6)
  aprovada_em       DateTime?                @db.Timestamptz(6)
  recusada_em       DateTime?                @db.Timestamptz(6)
  criado_em         DateTime                 @default(now()) @db.Timestamptz(6)
  atualizado_em     DateTime                 @default(now()) @db.Timestamptz(6)
  contratos         contratos[]
  proposta_itens    proposta_itens[]
  oportunidades     comercial_oportunidades? @relation(fields: [oportunidade_id], references: [id], onUpdate: NoAction)
  vendedores        comercial_vendedores?    @relation(fields: [vendedor_id], references: [id], onUpdate: NoAction)

  @@index([status], map: "idx_propostas_status")
  @@index([vendedor_id], map: "idx_propostas_vendedor")
  @@map("propostas")
  @@schema("comercial")
}

model comercial_vendedores {
  id                  BigInt                    @id @default(autoincrement())
  nome                String                    @db.VarChar(150)
  email               String?                   @unique @db.VarChar(255)
  whatsapp            String?                   @db.VarChar(30)
  meta_mensal         Decimal                   @default(0) @db.Decimal(14, 2)
  percentual_comissao Decimal                   @default(0) @db.Decimal(5, 2)
  status              String                    @default("ativo") @db.VarChar(30)
  criado_em           DateTime                  @default(now()) @db.Timestamptz(6)
  atualizado_em       DateTime                  @default(now()) @db.Timestamptz(6)
  atividades          atividades[]
  contratos           contratos[]
  leads               comercial_leads[]
  metas               metas[]
  oportunidades       comercial_oportunidades[]
  propostas           comercial_propostas[]
  comissoes           financeiro_comissoes[]

  @@map("vendedores")
  @@schema("comercial")
}

model crm_clientes {
  id                BigInt      @id @default(autoincrement())
